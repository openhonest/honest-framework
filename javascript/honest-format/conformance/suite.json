{
  "module": "honest-format",
  "note": "The portable honest-format conformance suite: language-agnostic input/output cases every implementation must pass. A case names a public function and its arguments; the runner resolves the function, applies it, and deep-compares the result. Ground truth is genX's fmtx (the reference of record): e.g. cents of '4250' formats as '$42.50', so convert('4250','cents') is 42.5. Date-valued and undefined-valued conversions are not JSON-expressible and are covered by the unit tests.",
  "cases": [
    {"id": "num-parse", "function": "toNumber", "args": ["42.5"], "expected": 42.5},
    {"id": "num-null", "function": "toNumber", "args": ["abc"], "expected": null},
    {"id": "convert-absent", "function": "convert", "args": ["x"], "expected": "x"},
    {"id": "convert-auto", "function": "convert", "args": ["x", "auto"], "expected": "x"},
    {"id": "convert-unknown", "function": "convert", "args": ["5", "bogus"], "expected": "5"},
    {"id": "convert-number", "function": "convert", "args": ["42", "number"], "expected": 42},
    {"id": "convert-cents", "function": "convert", "args": ["4250", "cents"], "expected": 42.5},
    {"id": "convert-pennies-alias", "function": "convert", "args": ["4250", "pennies"], "expected": 42.5},
    {"id": "convert-minutes", "function": "convert", "args": ["2", "minutes"], "expected": 120},
    {"id": "convert-hours", "function": "convert", "args": ["2", "hours"], "expected": 7200},
    {"id": "convert-kilobytes", "function": "convert", "args": ["2", "kilobytes"], "expected": 2000},
    {"id": "convert-megabytes", "function": "convert", "args": ["2", "megabytes"], "expected": 2000000},
    {"id": "convert-gigabytes", "function": "convert", "args": ["2", "gigabytes"], "expected": 2000000000},
    {"id": "convert-integer", "function": "convert", "args": ["3.9", "integer"], "expected": 3},
    {"id": "convert-decimal-alias", "function": "convert", "args": ["0.5", "decimal"], "expected": 0.5},
    {"id": "convert-string", "function": "convert", "args": [42, "string"], "expected": "42"},
    {"id": "convert-bool-false", "function": "convert", "args": ["false", "boolean"], "expected": false},
    {"id": "convert-bool-zero", "function": "convert", "args": ["0", "boolean"], "expected": false},
    {"id": "convert-bool-off-alias", "function": "convert", "args": ["off", "bool"], "expected": false},
    {"id": "convert-bool-true", "function": "convert", "args": ["yes", "boolean"], "expected": true},
    {"id": "convert-bool-empty", "function": "convert", "args": ["", "boolean"], "expected": false},
    {"id": "convert-null", "function": "convert", "args": ["x", "null"], "expected": null},

    {"id": "fmt-unknown", "function": "format", "args": ["unknownFormat", "hello"], "expected": "hello"},
    {"id": "fmt-number-nan", "function": "format", "args": ["number", "abc"], "expected": "abc"},
    {"id": "fmt-number", "function": "format", "args": ["number", "1234.5"], "expected": "1,234.50"},
    {"id": "fmt-number-nogroup", "function": "format", "args": ["number", "1234.5", {"thousands": false}], "expected": "1234.50"},
    {"id": "fmt-currency", "function": "format", "args": ["currency", "1299.99"], "expected": "$1,299.99"},
    {"id": "fmt-currency-eur", "function": "format", "args": ["currency", "1299.99", {"currency": "EUR"}], "expected": "€1,299.99"},
    {"id": "fmt-percent", "function": "format", "args": ["percent", "0.1567"], "expected": "16%"},
    {"id": "fmt-percent-2dp", "function": "format", "args": ["percent", "0.1567", {"decimals": 2}], "expected": "15.67%"},
    {"id": "fmt-percent-already", "function": "format", "args": ["percent", "15.67", {"type": "percentage", "decimals": 2}], "expected": "15.67%"},
    {"id": "fmt-scientific", "function": "format", "args": ["scientific", "12345"], "expected": "1.23e+4"},
    {"id": "fmt-accounting-neg", "function": "format", "args": ["accounting", "-1234.5"], "expected": "($1,234.50)"},
    {"id": "fmt-abbreviated-b", "function": "format", "args": ["abbreviated", "915166064277", {"decimals": 2, "prefix": "$"}], "expected": "$915.17B"},
    {"id": "fmt-abbreviated-plain", "function": "format", "args": ["abbreviated", "500"], "expected": "500.0"},
    {"id": "fmt-millions", "function": "format", "args": ["millions", "5000000"], "expected": "5.00M"},
    {"id": "fmt-filesize", "function": "format", "args": ["filesize", "1073741824"], "expected": "1.07 GB"},
    {"id": "fmt-filesize-zero", "function": "format", "args": ["filesize", "0"], "expected": "0 B"},
    {"id": "fmt-filesize-binary", "function": "format", "args": ["filesize", "1048576", {"binary": true}], "expected": "1.00 MiB"},
    {"id": "fmt-duration-short", "function": "format", "args": ["duration", "3661"], "expected": "1h 1m 1s"},
    {"id": "fmt-duration-clock-days", "function": "format", "args": ["duration", "90061", {"durationFormat": "clock"}], "expected": "1:01:01:01"},
    {"id": "fmt-duration-long", "function": "format", "args": ["duration", "90061", {"durationFormat": "long"}], "expected": "1 day, 1 hour, 1 minute, 1 second"},
    {"id": "fmt-fraction-mixed", "function": "format", "args": ["fraction", "1.5"], "expected": "1 1/2"},
    {"id": "fmt-fraction-proper", "function": "format", "args": ["fraction", "0.25"], "expected": "1/4"},
    {"id": "fmt-uppercase", "function": "format", "args": ["uppercase", "Hello"], "expected": "HELLO"},
    {"id": "fmt-capitalize", "function": "format", "args": ["capitalize", "hello world"], "expected": "Hello World"},
    {"id": "fmt-truncate", "function": "format", "args": ["truncate", "the quick brown fox", {"length": 9}], "expected": "the qu..."},
    {"id": "best-den-2", "function": "bestDenominator", "args": [0.5], "expected": 2},
    {"id": "best-den-4", "function": "bestDenominator", "args": [0.25], "expected": 4},
    {"id": "best-den-64", "function": "bestDenominator", "args": [0.333], "expected": 64},

    {"id": "num-date-parse", "function": "toDate", "args": ["not-a-date"], "expected": null},
    {"id": "fmt-date-iso", "function": "format", "args": ["date", "2024-03-15", {"dateFormat": "iso"}], "expected": "2024-03-15"},
    {"id": "fmt-date-bad", "function": "format", "args": ["date", "not-a-date"], "expected": "not-a-date"},
    {"id": "fmt-time-only", "function": "format", "args": ["time", "14:30:00"], "expected": "2:30 PM"},
    {"id": "fmt-relative-past", "function": "format", "args": ["relative", "2024-03-15T11:55:00.000Z", {"now": 1710504000000}], "expected": "5 minutes ago"},
    {"id": "fmt-relative-future", "function": "format", "args": ["relative", "2024-03-17T12:00:00.000Z", {"now": 1710504000000}], "expected": "in 2 days"},

    {"id": "fmt-phone-us", "function": "format", "args": ["phone", "5551234567"], "expected": "(555) 123-4567"},
    {"id": "fmt-phone-dash", "function": "format", "args": ["phone", "5551234567", {"phoneFormat": "us-dash"}], "expected": "555-123-4567"},
    {"id": "fmt-phone-intl-input", "function": "format", "args": ["phone", "+44 20 7946 0958"], "expected": "+44 20 7946 0958"},
    {"id": "fmt-phone-short", "function": "format", "args": ["phone", "12345"], "expected": "12345"},
    {"id": "fmt-ssn-masked", "function": "format", "args": ["ssn", "123456789"], "expected": "***-**-6789"},
    {"id": "fmt-ssn-full", "function": "format", "args": ["ssn", "123456789", {"mask": false}], "expected": "123-45-6789"},
    {"id": "fmt-cc-masked", "function": "format", "args": ["creditcard", "4111111111111111"], "expected": "****-****-****-1111"},
    {"id": "fmt-cc-full", "function": "format", "args": ["creditcard", "4111111111111111", {"mask": false}], "expected": "4111-1111-1111-1111"},
    {"id": "fmt-compact", "function": "format", "args": ["compact", "1500000"], "expected": "1.5M"}
  ]
}
