{
  "version": "0.1",
  "module": "honest-persist",
  "note": "Schema diff (section 5.1). Each case: current + target schema (plain dicts), and the operations diff() must produce in order. Increment 1: table/column create/drop/rename/alter in the safe emit order; dependency ordering (5.4) and ambiguity (5.3) follow with FK/index ops.",
  "cases": [
    {"id": "diff-create-table", "current": {}, "target": {"users": {"columns": {"id": {"type": "uuid"}}}}, "expect_operations": [{"op": "create_table", "table": "users"}]},
    {"id": "diff-drop-table", "current": {"users": {"columns": {"id": {"type": "uuid"}}}}, "target": {}, "expect_operations": [{"op": "drop_table", "table": "users"}]},
    {"id": "diff-no-change", "current": {"users": {"columns": {"id": {"type": "uuid"}}}}, "target": {"users": {"columns": {"id": {"type": "uuid"}}}}, "expect_operations": []},
    {"id": "diff-rename-table", "current": {"old_users": {"columns": {"id": {"type": "uuid"}}}}, "target": {"app_users": {"renamed_from": "old_users", "columns": {"id": {"type": "uuid"}}}}, "expect_operations": [{"op": "rename_table", "table": "old_users", "details": {"new_name": "app_users"}}]},
    {"id": "diff-add-column", "current": {"users": {"columns": {"id": {"type": "uuid"}}}}, "target": {"users": {"columns": {"id": {"type": "uuid"}, "email": {"type": "text"}}}}, "expect_operations": [{"op": "add_column", "table": "users", "details": {"column": "email"}}]},
    {"id": "diff-drop-column", "current": {"users": {"columns": {"id": {"type": "uuid"}, "email": {"type": "text"}}}}, "target": {"users": {"columns": {"id": {"type": "uuid"}}}}, "expect_operations": [{"op": "drop_column", "table": "users", "details": {"column": "email"}}]},
    {"id": "diff-rename-column", "current": {"users": {"columns": {"id": {"type": "uuid"}, "mail": {"type": "text"}}}}, "target": {"users": {"columns": {"id": {"type": "uuid"}, "email": {"renamed_from": "mail", "type": "text"}}}}, "expect_operations": [{"op": "rename_column", "table": "users", "details": {"from": "mail", "to": "email"}}]},
    {"id": "diff-alter-column-type", "current": {"users": {"columns": {"id": {"type": "text"}}}}, "target": {"users": {"columns": {"id": {"type": "uuid"}}}}, "expect_operations": [{"op": "alter_column", "table": "users", "details": {"column": "id"}}]},
    {"id": "diff-alter-column-no-change-on-unrelated", "current": {"users": {"columns": {"id": {"type": "uuid", "nullable": false}}}}, "target": {"users": {"columns": {"id": {"type": "uuid", "nullable": false}}}}, "expect_operations": []},
    {"id": "diff-fk-add-references-new-table", "current": {"tasks": {"columns": {"id": {"type": "uuid"}, "owner": {"type": "uuid"}}}}, "target": {"tasks": {"columns": {"id": {"type": "uuid"}, "owner": {"type": "uuid", "references": "users.id"}}}, "users": {"columns": {"id": {"type": "uuid"}}}}, "expect_operations": [{"op": "create_table", "table": "users"}, {"op": "add_foreign_key", "table": "tasks", "details": {"column": "owner", "references": "users.id"}}]},
    {"id": "diff-fk-drop", "current": {"tasks": {"columns": {"id": {"type": "uuid"}, "owner": {"type": "uuid", "references": "users.id"}}}, "users": {"columns": {"id": {"type": "uuid"}}}}, "target": {"tasks": {"columns": {"id": {"type": "uuid"}, "owner": {"type": "uuid"}}}, "users": {"columns": {"id": {"type": "uuid"}}}}, "expect_operations": [{"op": "drop_foreign_key", "table": "tasks", "details": {"column": "owner", "references": "users.id"}}]},
    {"id": "diff-index-add", "current": {"users": {"columns": {"email": {"type": "text"}}}}, "target": {"users": {"columns": {"email": {"type": "text"}}, "indexes": {"users_email": {"columns": ["email"], "unique": true}}}}, "expect_operations": [{"op": "add_index", "table": "users", "details": {"index": "users_email"}}]},
    {"id": "diff-index-drop", "current": {"users": {"columns": {"email": {"type": "text"}}, "indexes": {"users_email": {"columns": ["email"]}}}}, "target": {"users": {"columns": {"email": {"type": "text"}}}}, "expect_operations": [{"op": "drop_index", "table": "users", "details": {"index": "users_email"}}]},
    {"id": "diff-constraint-add", "current": {"users": {"columns": {"age": {"type": "integer"}}}}, "target": {"users": {"columns": {"age": {"type": "integer"}}, "constraints": {"age_positive": {"type": "check", "expression": "age > 0"}}}}, "expect_operations": [{"op": "add_constraint", "table": "users", "details": {"constraint": "age_positive"}}]},
    {"id": "ambiguity-similar-name-high-confidence", "current": {"users": {"columns": {"naem": {"type": "text"}}}}, "target": {"users": {"columns": {"name": {"type": "text"}}}}, "expect_ambiguities": 1, "expect_confidence": 1.0},
    {"id": "ambiguity-same-type-different-name", "current": {"users": {"columns": {"email": {"type": "text"}}}}, "target": {"users": {"columns": {"contact_address": {"type": "text"}}}}, "expect_ambiguities": 1, "expect_confidence": 0.7},
    {"id": "ambiguity-type-differs-not-reported", "current": {"users": {"columns": {"a": {"type": "text"}}}}, "target": {"users": {"columns": {"b": {"type": "integer"}}}}, "expect_ambiguities": 0},
    {"id": "ambiguity-resolved-by-renamed-from", "current": {"users": {"columns": {"old": {"type": "text"}}}}, "target": {"users": {"columns": {"new": {"renamed_from": "old", "type": "text"}}}}, "expect_ambiguities": 0},
    {"id": "ambiguity-resolved-by-decisions", "current": {"users": {"columns": {"email": {"type": "text"}}}}, "target": {"users": {"columns": {"contact_address": {"type": "text"}}}}, "decisions": {"users.contact_address": {"decision": "drop_and_add"}}, "expect_ambiguities": 0},

    {"id": "tosql-create-table", "to_sql": {"op": "create_table", "table": "users", "details": {"columns": {"id": {"type": "uuid", "primary_key": true}, "email": {"type": "text"}}}}, "dialect": "postgresql", "expect_sql": "CREATE TABLE users (id uuid PRIMARY KEY, email text)"},
    {"id": "tosql-uuid-maps-to-text-on-sqlite", "to_sql": {"op": "create_table", "table": "t", "details": {"columns": {"id": {"type": "uuid"}}}}, "dialect": "sqlite", "expect_sql": "CREATE TABLE t (id text)"},
    {"id": "tosql-rename-column", "to_sql": {"op": "rename_column", "table": "users", "details": {"from": "mail", "to": "email"}}, "dialect": "postgresql", "expect_sql": "ALTER TABLE users RENAME COLUMN mail TO email"},
    {"id": "tosql-add-foreign-key", "to_sql": {"op": "add_foreign_key", "table": "tasks", "details": {"column": "owner", "references": "users.id"}}, "dialect": "postgresql", "expect_sql": "ALTER TABLE tasks ADD CONSTRAINT fk_tasks_owner FOREIGN KEY (owner) REFERENCES users (id)"},
    {"id": "tosql-add-index-unique", "to_sql": {"op": "add_index", "table": "users", "details": {"index": "users_email", "definition": {"columns": ["email"], "unique": true}}}, "dialect": "postgresql", "expect_sql": "CREATE UNIQUE INDEX users_email ON users (email)"},

    {"id": "apply-success-executes-in-order", "apply": {"current": {}, "target": {"users": {"columns": {"id": {"type": "uuid"}}}}}, "dialect": "postgresql", "expect_success": true, "expect_applied": 1},
    {"id": "apply-refuses-on-ambiguity", "apply": {"current": {"users": {"columns": {"email": {"type": "text"}}}}, "target": {"users": {"columns": {"contact_address": {"type": "text"}}}}}, "dialect": "postgresql", "expect_success": false},

    {"id": "validate-valid-fk", "validate": {"users": {"columns": {"id": {"type": "uuid"}}}, "tasks": {"columns": {"id": {"type": "uuid"}, "owner": {"type": "uuid", "references": "users.id"}}}}, "expect": "ok"},
    {"id": "validate-fk-unknown-table", "validate": {"tasks": {"columns": {"owner": {"type": "uuid", "references": "ghosts.id"}}}}, "expect": "invalid", "expect_error_contains": "unknown table 'ghosts'"},
    {"id": "validate-fk-unknown-column", "validate": {"users": {"columns": {"id": {"type": "uuid"}}}, "tasks": {"columns": {"owner": {"type": "uuid", "references": "users.nope"}}}}, "expect": "invalid", "expect_error_contains": "unknown column 'users.nope'"},
    {"id": "validate-pk-missing-column", "validate": {"users": {"columns": {"id": {"type": "uuid"}}, "primary_key": ["ghost"]}}, "expect": "invalid", "expect_error_contains": "primary_key names missing column 'ghost'"},
    {"id": "validate-index-missing-column", "validate": {"users": {"columns": {"id": {"type": "uuid"}}, "indexes": {"users_email": {"columns": ["email"]}}}}, "expect": "invalid", "expect_error_contains": "index names missing column 'email'"},
    {"id": "diff-rejects-invalid-target", "current": {}, "target": {"tasks": {"columns": {"owner": {"type": "uuid", "references": "ghosts.id"}}}}, "expect_fault": "schema_invalid"},

    {"id": "ext-create-view", "current": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}}, "target": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}, "views": {"active_users": {"query": "SELECT * FROM users", "depends_on": ["users"]}}}, "expect_operations": [{"op": "create_view", "table": "", "details": {"view": "active_users"}}]},
    {"id": "ext-drop-view", "current": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}, "views": {"v": {"query": "SELECT 1"}}}, "target": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}}, "expect_operations": [{"op": "drop_view", "table": "", "details": {"view": "v"}}]},
    {"id": "ext-change-view-drops-and-recreates", "current": {"tables": {}, "views": {"v": {"query": "SELECT 1"}}}, "target": {"tables": {}, "views": {"v": {"query": "SELECT 2"}}}, "expect_operations": [{"op": "drop_view", "table": "", "details": {"view": "v"}}, {"op": "create_view", "table": "", "details": {"view": "v"}}]},
    {"id": "ext-create-trigger", "current": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}}, "target": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}, "triggers": {"t": {"table": "users", "timing": "after", "events": ["insert"], "body": "..."}}}, "expect_operations": [{"op": "create_trigger", "table": "users", "details": {"trigger": "t"}}]},
    {"id": "ext-create-function", "current": {"tables": {}}, "target": {"tables": {}, "procedures": {"f": {"kind": "function", "returns": "integer", "body": "..."}}}, "expect_operations": [{"op": "create_function", "table": "", "details": {"function": "f"}}]},
    {"id": "ext-replace-function", "current": {"tables": {}, "procedures": {"f": {"kind": "function", "body": "a"}}}, "target": {"tables": {}, "procedures": {"f": {"kind": "function", "body": "b"}}}, "expect_operations": [{"op": "replace_function", "table": "", "details": {"function": "f"}}]},
    {"id": "ext-change-procedure-drops-and-recreates", "current": {"tables": {}, "procedures": {"p": {"kind": "procedure", "body": "a"}}}, "target": {"tables": {}, "procedures": {"p": {"kind": "procedure", "body": "b"}}}, "expect_operations": [{"op": "drop_function", "table": "", "details": {"function": "p"}}, {"op": "create_function", "table": "", "details": {"function": "p"}}]},
    {"id": "ext-view-ordered-after-its-table", "current": {"tables": {}}, "target": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}, "views": {"active": {"query": "SELECT * FROM users", "depends_on": ["users"]}}}, "expect_operations": [{"op": "create_table", "table": "users"}, {"op": "create_view", "table": "", "details": {"view": "active"}}]},
    {"id": "validate-view-depends-unknown", "validate": {"tables": {}, "views": {"v": {"query": "...", "depends_on": ["ghosts"]}}}, "expect": "invalid", "expect_error_contains": "depends_on unknown object 'ghosts'"},

    {"id": "requires-reconstruction-sqlite-alter", "reconstruct_op": {"op": "alter_column", "table": "t", "details": {}}, "dialect": "sqlite", "expect": true},
    {"id": "requires-reconstruction-postgres-alter-false", "reconstruct_op": {"op": "alter_column", "table": "t", "details": {}}, "dialect": "postgresql", "expect": false},
    {"id": "requires-reconstruction-add-column-false", "reconstruct_op": {"op": "add_column", "table": "t", "details": {}}, "dialect": "sqlite", "expect": false},
    {"id": "reconstruction-sql-plan", "reconstruct_sql": {"table": "users", "target_table": {"columns": {"id": {"type": "uuid"}, "email": {"type": "text"}}}, "common_columns": ["id"]}, "dialect": "sqlite", "expect_contains": ["CREATE TABLE _hp_tmp_users", "INSERT INTO _hp_tmp_users (id) SELECT id FROM users", "DROP TABLE users", "ALTER TABLE _hp_tmp_users RENAME TO users"]},
    {"id": "apply-reconstructs-on-sqlite-alter-column", "apply": {"current": {"tables": {"users": {"columns": {"id": {"type": "text"}}}}}, "target": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}}}, "dialect": "sqlite", "expect_success": true, "expect_executed_contains": ["CREATE TABLE _hp_tmp_users", "INSERT INTO _hp_tmp_users (id) SELECT id FROM users", "DROP TABLE users", "ALTER TABLE _hp_tmp_users RENAME TO users"]},
    {"id": "apply-postgres-alters-in-place-no-reconstruction", "apply": {"current": {"tables": {"users": {"columns": {"id": {"type": "text"}}}}}, "target": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}}}, "dialect": "postgresql", "expect_success": true, "expect_executed_contains": ["ALTER COLUMN id TYPE uuid"], "expect_executed_excludes": ["_hp_tmp"]},
    {"id": "apply-turso-pauses-push-during-reconstruction", "apply": {"current": {"tables": {"users": {"columns": {"id": {"type": "text"}}}}}, "target": {"tables": {"users": {"columns": {"id": {"type": "uuid"}}}}}}, "dialect": "turso", "expect_success": true, "expect_push_paused": true, "expect_executed_contains": ["CREATE TABLE _hp_tmp_users"]}
  ]
}
