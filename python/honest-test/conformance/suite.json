{
  "version": "0.1",
  "module": "honest-test",
  "note": "Unit 1 - generation engine. enumeration: Set cartesian product (section 3.2), maybe adds Nothing (null). adversarial: neighbour classes (section 3.5). Cases are data; the runner builds the vocabulary and calls the generators. Non-printable neighbours are encoded as JSON \\u escapes. The two byte-level Class 5 variants are deferred, so encoding cases assert only the string-valued variants.",
  "cases": [
    {
      "id": "enum-product-2x2",
      "declarations": {
        "a": [
          "x",
          "y"
        ],
        "b": [
          "1",
          "2"
        ]
      },
      "expect_count": 4,
      "expect_contains": [
        {
          "a": "x",
          "b": "1"
        },
        {
          "a": "y",
          "b": "2"
        }
      ]
    },
    {
      "id": "enum-single-set",
      "declarations": {
        "t": [
          "alpha",
          "beta",
          "gamma"
        ]
      },
      "expect_count": 3,
      "expect_contains": [
        {
          "t": "alpha"
        },
        {
          "t": "gamma"
        }
      ]
    },
    {
      "id": "enum-three-sets-product",
      "declarations": {
        "a": [
          "x"
        ],
        "b": [
          "1",
          "2"
        ],
        "c": [
          "p",
          "q"
        ]
      },
      "expect_count": 4
    },
    {
      "id": "enum-maybe-adds-nothing",
      "declarations": {
        "a": [
          "x",
          "y"
        ]
      },
      "maybe": [
        "a"
      ],
      "expect_count": 3,
      "expect_contains": [
        {
          "a": "x"
        },
        {
          "a": "y"
        },
        {
          "a": null
        }
      ]
    },
    {
      "id": "adv-edit-distance-and-control",
      "value": "USD",
      "expect_contains": [
        "US",
        "UD",
        "SD",
        "usd",
        "Usd",
        " USD",
        "USD ",
        "U SD"
      ],
      "expect_excludes": [
        "USD"
      ],
      "expect_count_min": 100
    },
    {
      "id": "adv-confusable-cyrillic-a",
      "value": "abc",
      "expect_contains": [
        "\u0430bc"
      ]
    },
    {
      "id": "adv-encoding-string-variants",
      "value": "a b",
      "expect_contains": [
        "\ufeffa b",
        "a%2520b",
        "a\u00a0b",
        "a\u2028b"
      ],
      "expect_excludes": [
        "a b"
      ]
    },
    {
      "id": "adv-bidi-override-injected",
      "value": "USD",
      "expect_contains": [
        "\u202eUSD",
        "USD\u202e"
      ]
    },
    {"id": "pred-numeric-int", "source": "lambda s: int(s) > 0", "expect_class": "numeric"},
    {"id": "pred-numeric-float", "source": "def f(s):\n    return float(s) < 1.0\n", "expect_class": "numeric"},
    {"id": "pred-length-eq", "source": "def f(s):\n    return len(s) == 5\n", "expect_class": "length"},
    {"id": "pred-length-lt", "source": "lambda s: len(s) < 10", "expect_class": "length"},
    {"id": "pred-charclass-isdigit", "source": "lambda s: s.isdigit()", "expect_class": "character_class"},
    {"id": "pred-charclass-isalpha", "source": "def f(s):\n    return s.isalpha()\n", "expect_class": "character_class"},
    {"id": "pred-catchall-true", "source": "lambda s: True", "expect_class": "catch_all"},
    {"id": "pred-catchall-isinstance", "source": "lambda s: isinstance(s, str)", "expect_class": "catch_all"},
    {"id": "pred-external-call", "source": "lambda s: lookup(s)", "expect_class": "external"},
    {"id": "pred-composite-call", "source": "lambda s: validate(s)", "codebase": ["validate"], "expect_class": "composite"},
    {"id": "pred-length-beats-numeric", "source": "lambda s: len(s) == 5", "expect_class": "length"},
    {"id": "pred-unknown-string-compare", "source": "lambda s: s == 'x'", "expect_class": "unknown"},
    {"id": "numeric-fib-limit-10", "gen": "numeric", "limit": 10, "expect_values": [-1, -1, -2, -3, -5, -8, -13, 0, 1, 1, 2, 3, 5, 8, 13]},
    {"id": "numeric-no-negative", "gen": "numeric", "limit": 10, "negative": false, "expect_values": [0, 1, 1, 2, 3, 5, 8, 13]},
    {"id": "numeric-float-divides-by-100", "gen": "numeric", "limit": 10, "as_float": true, "expect_contains": [0.0, 0.01, 0.05, 0.13, -0.13]},
    {"id": "numeric-default-spread", "gen": "numeric", "expect_contains": [0, 1, -1], "expect_count_min": 40},
    {"id": "length-exact-eq", "gen": "length", "source": "lambda s: len(s) == 5", "expect_min": 5, "expect_max": 5, "expect_valid_lengths": [5], "expect_invalid_lengths": [4, 6]},
    {"id": "length-le", "gen": "length", "source": "lambda s: len(s) <= 8", "expect_min": 1, "expect_max": 8, "expect_valid_lengths": [1, 2, 3, 4, 5, 6, 7, 8], "expect_invalid_lengths": [9]},
    {"id": "length-lt", "gen": "length", "source": "lambda s: len(s) < 8", "expect_min": 1, "expect_max": 7, "expect_valid_lengths": [1, 2, 3, 4, 5, 6, 7], "expect_invalid_lengths": [8]},
    {"id": "length-range-tests-one-under", "gen": "length", "source": "def f(s):\n    return 3 <= len(s) <= 8\n", "expect_min": 3, "expect_max": 8, "expect_valid_lengths": [3, 4, 5, 6, 7, 8], "expect_invalid_lengths": [2, 9]},
    {"id": "length-ge-unbounded-falls-through", "gen": "length", "source": "lambda s: len(s) >= 3", "expect_min": 3, "expect_max": null, "expect_valid_lengths": [], "expect_invalid_lengths": []},
    {"id": "length-beyond-charset", "gen": "length", "source": "lambda s: len(s) == 50", "expect_min": 50, "expect_max": 50, "expect_valid_lengths": [50], "expect_invalid_lengths": [49, 51]},
    {"id": "supplied-from-toml", "toml": "[predicates.customer_id]\nvalid = [\"CUST-00001\", \"CUST-99999\"]\ninvalid = [\"CUST-0\", \"cust-00001\"]\nstrategy = \"supplied_only\"\n", "predicate": "customer_id", "expect_valid": ["CUST-00001", "CUST-99999"], "expect_invalid": ["CUST-0", "cust-00001"], "expect_strategy": "supplied_only"},
    {"id": "supplied-toml-string-NO-stays-string", "toml": "[predicates.country]\nvalid = [\"NO\", \"SE\"]\ninvalid = [\"XX\"]\n", "predicate": "country", "expect_valid": ["NO", "SE"], "expect_invalid": ["XX"]},
    {"id": "supplied-missing-predicate", "config": {"predicates": {}}, "predicate": "absent", "expect_none": true},
    {"id": "supplied-defaults", "config": {"predicates": {"p": {}}}, "predicate": "p", "expect_valid": [], "expect_invalid": [], "expect_strategy": "supplied_only"},
    {"id": "honesty-purity-pure-link", "honesty": "purity", "link": "pure", "manifest": {"x": "1"}, "expect_ok": true},
    {"id": "honesty-purity-impure-link", "honesty": "purity", "link": "impure", "manifest": {"x": "1"}, "expect_ok": false, "expect_code": "non_deterministic"},
    {"id": "honesty-purity-boundary-exempt", "honesty": "purity", "link": "boundary_impure", "manifest": {"x": "1"}, "expect_ok": true},
    {"id": "honesty-mutation-pure-link", "honesty": "mutation", "link": "pure", "manifest": {"x": "1"}, "expect_ok": true},
    {"id": "honesty-mutation-mutating-link", "honesty": "mutation", "link": "mutating", "manifest": {"x": "1"}, "expect_ok": false, "expect_code": "manifest_mutated"},
    {"id": "honesty-idempotency-pure-chain", "honesty": "idempotency", "chain": ["pure", "set_role"], "manifest": {"x": "1"}, "expect_ok": true},
    {"id": "honesty-idempotency-impure-chain", "honesty": "idempotency", "chain": ["impure"], "manifest": {"x": "1"}, "expect_ok": false, "expect_code": "not_idempotent"},
    {"id": "contract-server-fault-is-violation", "contract": true, "chain": ["emit_format", "accepts_currency"], "expect_ok": false},
    {"id": "contract-client-fault-not-violation", "contract": true, "chain": ["emit_format", "client_picky"], "expect_ok": true},
    {"id": "contract-all-outputs-accepted", "contract": true, "chain": ["emit_format", "always_ok"], "expect_ok": true},
    {"id": "sm-valid-transitions-clean", "sm_test": "valid", "states": ["pending", "paid", "shipped", "cancelled"], "events": ["pay", "ship", "cancel", "refund"], "transitions": [["pending", "pay", "paid"], ["pending", "cancel", "cancelled"], ["paid", "ship", "shipped"], ["paid", "cancel", "cancelled"], ["shipped", "refund", "cancelled"]], "initial": "pending", "expect_findings": 0},
    {"id": "sm-invalid-transitions-clean", "sm_test": "invalid", "states": ["pending", "paid", "shipped", "cancelled"], "events": ["pay", "ship", "cancel", "refund"], "transitions": [["pending", "pay", "paid"], ["pending", "cancel", "cancelled"], ["paid", "ship", "shipped"], ["paid", "cancel", "cancelled"], ["shipped", "refund", "cancelled"]], "initial": "pending", "expect_findings": 0},
    {"id": "sm-adversarial-clean", "sm_test": "adversarial", "states": ["pending", "paid", "shipped", "cancelled"], "events": ["pay", "ship", "cancel", "refund"], "transitions": [["pending", "pay", "paid"]], "initial": "pending", "expect_findings": 0},
    {"id": "sm-adversarial-detects-similar-states", "sm_test": "adversarial", "states": ["cat", "car"], "events": ["go"], "transitions": [["cat", "go", "car"]], "initial": "cat", "expect_min_findings": 1},
    {"id": "proof-payload-proved", "proof_payload": {"args": {"function": "honest_observe.events.build_event", "gherkin": "build_event assembles a validated envelope", "module": "honest-observe", "cases": 12, "result": "proved", "failures": [], "line_coverage": 100.0, "branch_coverage": 100.0}}, "expect": {"function": "honest_observe.events.build_event", "gherkin": "build_event assembles a validated envelope", "module": "honest-observe", "cases": 12, "result": "proved", "failures": [], "line_coverage": 100.0, "branch_coverage": 100.0}},
    {"id": "proof-payload-failed", "proof_payload": {"args": {"function": "m.f", "gherkin": "f does the thing", "module": "m", "cases": 4, "result": "failed", "failures": ["case 3: wrong output"], "line_coverage": 80.0, "branch_coverage": 50.0}}, "expect": {"function": "m.f", "gherkin": "f does the thing", "module": "m", "cases": 4, "result": "failed", "failures": ["case 3: wrong output"], "line_coverage": 80.0, "branch_coverage": 50.0}},
    {"id": "value-returns", "value_case": {"function": "double", "input": 21, "expected": 42}},
    {"id": "value-returns-list", "value_case": {"function": "double", "input": [1, 2], "expected": [1, 2, 1, 2]}},
    {"id": "value-fault", "value_case": {"function": "parity", "input": 3, "fault": "odd"}},
    {"id": "value-ok", "value_case": {"function": "parity", "input": 4, "ok": true}},
    {"id": "value-field", "value_case": {"function": "box", "input": 5, "field": {"name": "n", "value": 5}}},
    {"id": "value-fib-5", "value_case": {"function": "fibonacci_sequence", "input": 5, "expected": [-1, -1, -2, -3, -5, 0, 1, 1, 2, 3, 5]}},
    {"id": "value-fib-20", "value_case": {"function": "fibonacci_sequence", "input": 20, "expected": [-1, -1, -2, -3, -5, -8, -13, -21, 0, 1, 1, 2, 3, 5, 8, 13, 21]}},
    {"id": "value-numeric-5", "value_case": {"function": "numeric_values", "input": 5, "expected": [-1, -1, -2, -3, -5, 0, 1, 1, 2, 3, 5]}},
    {"id": "value-ref", "value_case": {"function": "apply_fn", "args": [{"$ref": "double"}, 21], "expected": 42}},
    {"id": "value-nested-call", "value_case": {"function": "double", "args": [{"$call": "double", "args": [10]}], "expected": 40}},
    {"id": "value-kwargs", "value_case": {"function": "double", "kwargs": {"x": 21}, "expected": 42}},
    {"id": "value-async", "value_case": {"function": "add_async", "args": [2, 3], "expected": 5}},
    {"id": "value-dict-literal", "value_case": {"function": "echo", "input": {"k": "v"}, "expected": {"k": "v"}}},
    {"id": "value-decide-proof", "value_case": {"function": "decide_proof", "args": [true, true, [{"id": "v1", "proved": true, "fault": null}]], "expected": {"result": "proved", "failures": []}}},
    {"id": "value-proof-payload", "value_case": {"function": "proof_payload", "args": ["m.f", "f does x", "m", 3, "proved", [], 100.0, 100.0], "expected": {"function": "m.f", "gherkin": "f does x", "module": "m", "cases": 3, "result": "proved", "failures": [], "line_coverage": 100.0, "branch_coverage": 100.0}}},
    {"id": "value-check-oracle", "value_case": {"function": "check_oracle", "args": [{"expected": 4}, 4], "expected": null}},
    {"id": "value-classify-source", "value_case": {"function": "classify_source", "input": "def f(x):\n    return len(x) < 10\n", "expected": "length"}},
    {"id": "value-encoding-variants", "value_case": {"function": "encoding_variants", "input": "a", "expected": ["﻿a", "a", "a", "a"]}},
    {"id": "value-enumerate-lengths", "value_case": {"function": "enumerate_lengths", "input": "len(x) < 5", "expected": {"min": 1, "max": 4, "valid": ["a", "ab", "abc", "abcd"], "invalid": ["abcde"]}}},
    {"id": "value-load-config", "value_case": {"function": "load_config", "input": "/nonexistent/honest-test.toml", "expected": {}}},
    {"id": "value-classify-predicate", "value_case": {"function": "classify_predicate", "args": [{"$ref": "fibonacci_sequence"}], "expected": "numeric"}},
    {"id": "decide-proved", "decide": {"honesty_ok": true, "coverage_ok": true, "value_results": [{"id": "v1", "proved": true, "fault": null}]}, "expect": {"result": "proved", "failures": []}},
    {"id": "decide-value-mismatch", "decide": {"honesty_ok": true, "coverage_ok": true, "value_results": [{"id": "v1", "proved": true, "fault": null}, {"id": "v2", "proved": false, "fault": {"code": "assertion_failed", "detail": "expected 42, got 7", "scenario_name": "", "step_text": ""}}]}, "expect": {"result": "failed", "failures": ["value case 'v2': expected 42, got 7"]}},
    {"id": "decide-no-oracle", "decide": {"honesty_ok": true, "coverage_ok": true, "value_results": []}, "expect": {"result": "failed", "failures": ["no value oracle: the function's Then is not yet checked by a value case"]}},
    {"id": "decide-honesty-fail", "decide": {"honesty_ok": false, "coverage_ok": true, "value_results": [{"id": "v1", "proved": true, "fault": null}]}, "expect": {"result": "failed", "failures": ["honesty checks did not pass"]}},
    {"id": "decide-coverage-fail", "decide": {"honesty_ok": true, "coverage_ok": false, "value_results": [{"id": "v1", "proved": true, "fault": null}]}, "expect": {"result": "failed", "failures": ["not fully covered (line or branch below 100%)"]}}
  ]
}
