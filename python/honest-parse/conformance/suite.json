{
  "version": "0.1",
  "module": "honest-parse",
  "note": "The shared tree-sitter parsing boundary. error cases assert syntax-error detection; text cases assert the root node spans the whole source. Cases are data; the runner parses and checks.",
  "cases": [
    {"id": "valid-assignment", "source": "x = 1", "expect_error": false},
    {"id": "valid-function", "source": "def f():\n    return 1\n", "expect_error": false},
    {"id": "valid-empty", "source": "", "expect_error": false},
    {"id": "syntax-error-def", "source": "def f(:", "expect_error": true},
    {"id": "unterminated-string", "source": "x = 'abc", "expect_error": true},
    {"id": "root-text-spans-source", "source": "a = 2", "expect_root_text": "a = 2"},
    {"id": "js-valid-const", "language": "javascript", "source": "const x = 1;", "expect_error": false},
    {"id": "js-valid-function", "language": "javascript", "source": "function f() {\n    return 1;\n}\n", "expect_error": false},
    {"id": "js-valid-empty", "language": "javascript", "source": "", "expect_error": false},
    {"id": "js-syntax-error", "language": "javascript", "source": "function f(", "expect_error": true},
    {"id": "js-unterminated-string", "language": "javascript", "source": "const x = 'abc", "expect_error": true},
    {"id": "js-root-text-spans-source", "language": "javascript", "source": "let a = 2;", "expect_root_text": "let a = 2;"}
  ]
}
