  "cases": [
    {"id": "value-vocab-ok", "value_case": {"function": "validate_vocabulary", "args": [{"f": {"states": ["on", "off"], "initial_value": "off"}}], "expected": {"ok": {"f": {"states": ["on", "off"], "initial_value": "off"}}}}},
    {"id": "value-vocab-too-few", "value_case": {"function": "validate_vocabulary", "args": [{"f": {"states": ["on"], "initial_value": "on"}}], "expected": {"err": {"code": "invalid_vocabulary", "message": "flags violate the vocabulary rules: ['f']", "category": "client", "detail": ["f"]}}}},
    {"id": "value-vocab-bad-initial-value", "value_case": {"function": "validate_vocabulary", "args": [{"f": {"states": ["on", "off"], "initial_value": "x"}}], "expected": {"err": {"code": "invalid_vocabulary", "message": "flags violate the vocabulary rules: ['f']", "category": "client", "detail": ["f"]}}}},
    {"id": "value-vocab-extra-key", "value_case": {"function": "validate_vocabulary", "args": [{"f": {"states": ["on", "off"], "initial_value": "off", "owner": "team"}}], "expected": {"err": {"code": "invalid_vocabulary", "message": "flags violate the vocabulary rules: ['f']", "category": "client", "detail": ["f"]}}}},
    {"id": "value-vocab-missing-initial-value", "value_case": {"function": "validate_vocabulary", "args": [{"f": {"states": ["on", "off"]}}], "expected": {"err": {"code": "invalid_vocabulary", "message": "flags violate the vocabulary rules: ['f']", "category": "client", "detail": ["f"]}}}},
    {"id": "value-vocab-duplicate-states", "value_case": {"function": "validate_vocabulary", "args": [{"f": {"states": ["on", "on"], "initial_value": "on"}}], "expected": {"err": {"code": "invalid_vocabulary", "message": "flags violate the vocabulary rules: ['f']", "category": "client", "detail": ["f"]}}}},
    {"id": "value-initial-state", "value_case": {"function": "initial_state", "args": [{"a": {"states": ["on", "off"], "initial_value": "off"}, "b": {"states": ["x", "y"], "initial_value": "y"}}], "expected": {"a": "off", "b": "y"}}},
    {"id": "value-feature-state", "value_case": {"function": "feature_state", "args": [{"a": "on", "b": "off"}, "a"], "expected": "on"}},
    {"id": "value-toggle-ok", "value_case": {"function": "validate_toggle", "args": [{"f": {"states": ["on", "off"], "initial_value": "off"}}, "f", "on"], "expected": {"ok": {"flag": "f", "state": "on"}}}},
    {"id": "value-toggle-unknown-flag", "value_case": {"function": "validate_toggle", "args": [{"f": {"states": ["on", "off"], "initial_value": "off"}}, "ghost", "on"], "expected": {"err": {"code": "unknown_flag", "message": "'ghost' is not a declared flag", "category": "client", "detail": "ghost"}}}},
    {"id": "value-toggle-invalid-state", "value_case": {"function": "validate_toggle", "args": [{"f": {"states": ["on", "off"], "initial_value": "off"}}, "f", "maybe"], "expected": {"err": {"code": "invalid_state", "message": "'maybe' is not a state of 'f'", "category": "client", "detail": "maybe"}}}},
    {"id": "value-apply-toggle", "value_case": {"function": "apply_toggle", "args": [{"f": "off", "g": "on"}, "f", "on"], "expected": {"previous": "off", "state": {"f": "on", "g": "on"}}}},
    {"id": "value-changed-event", "value_case": {"function": "changed_event", "args": ["new_checkout", "off", "on", 1710000000, "10.0.0.1"], "expected": {"event_type": "hf.features.changed", "flag": "new_checkout", "previous": "off", "state": "on", "timestamp": 1710000000, "requesting_ip": "10.0.0.1"}}},
    {"id": "value-evaluated-event", "value_case": {"function": "evaluated_event", "args": ["new_checkout", "on", "req_abc123"], "expected": {"event_type": "hf.features.evaluated", "flag": "new_checkout", "state": "on", "request_id": "req_abc123"}}}
  ]
}
