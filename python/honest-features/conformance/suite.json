{
  "module": "honest-features",
  "value_oracle_exempt": [
    {"function": "build_signature", "reason": "Section 5.2: the secret is bytes, which a JSON value case cannot carry. The HMAC round trip is proved by the build_signature and verify_signature laws in laws_hf.py."},
    {"function": "verify_signature", "reason": "Section 5.2: the secret is bytes, which a JSON value case cannot carry. The replay-window and constant-time-compare branches are proved by the verify_signature law in laws_hf.py."}
