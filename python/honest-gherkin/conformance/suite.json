{
  "version": "0.1",
  "module": "honest-gherkin",
  "cases": [
    {"id": "parse-simple", "parse": {"source": "Feature: Login\n\n  Scenario: a user signs in\n    Given a registered user\n    When they sign in\n    Then they reach the dashboard\n", "path": "login.feature"}, "expect": "ok", "expect_feature_name": "Login", "expect_scenarios": 1, "expect_first_steps": 3},
    {"id": "parse-description-and-tags", "parse": {"source": "Feature: Orders\n  Orders can be placed and cancelled.\n\n  @smoke @fast\n  Scenario: place an order\n    Given an empty cart\n    And a logged-in user\n    When the order is placed\n    Then it is recorded\n", "path": "orders.feature"}, "expect": "ok", "expect_feature_name": "Orders", "expect_scenarios": 1, "expect_first_steps": 4},
    {"id": "parse-two-scenarios", "parse": {"source": "Feature: Two\n\n  Scenario: one\n    Given a\n    Then b\n\n  Scenario: two\n    When c\n    Then d\n", "path": "two.feature"}, "expect": "ok", "expect_feature_name": "Two", "expect_scenarios": 2, "expect_first_steps": 2},
    {"id": "parse-comments-tolerated", "parse": {"source": "# a comment\nFeature: WithComments\n\n  # another\n  Scenario: works\n    Given a\n    Then b\n", "path": "c.feature"}, "expect": "ok", "expect_feature_name": "WithComments", "expect_scenarios": 1, "expect_first_steps": 2},
    {"id": "parse-step-outside-scenario", "parse": {"source": "Feature: X\n  Given an orphan step\n", "path": "x.feature"}, "expect": "err", "expect_code": "bad_feature_syntax"},
    {"id": "parse-scenario-no-name", "parse": {"source": "Feature: X\n\n  Scenario:\n    Given a\n", "path": "x.feature"}, "expect": "err", "expect_code": "bad_feature_syntax"},
    {"id": "compile-str-default", "compile": {"pattern": "say \"{word}\""}, "expect": "ok", "expect_captures": [{"name": "word", "type": "str"}]},
    {"id": "compile-typed", "compile": {"pattern": "n {x:int} f {y:float}"}, "expect": "ok", "expect_captures": [{"name": "x", "type": "int"}, {"name": "y", "type": "float"}]},
    {"id": "compile-no-placeholder", "compile": {"pattern": "plain text"}, "expect": "ok", "expect_captures": []},
    {"id": "compile-unknown-type", "compile": {"pattern": "a {x:widget}"}, "expect": "err", "expect_code": "bad_feature_syntax"},
    {"id": "match-one-str", "match": {"patterns": [{"kind": "given", "pattern": "a user named \"{name}\"", "handler": "h"}], "step_text": "a user named \"Ada\""}, "expect": "ok", "expect_captures": {"name": "Ada"}},
    {"id": "match-coerce-int", "match": {"patterns": [{"kind": "when", "pattern": "add {x:int}", "handler": "h"}], "step_text": "add 42"}, "expect": "ok", "expect_captures": {"x": 42}},
    {"id": "match-coerce-float", "match": {"patterns": [{"kind": "then", "pattern": "it is {y:float}", "handler": "h"}], "step_text": "it is 3.14"}, "expect": "ok", "expect_captures": {"y": 3.14}},
    {"id": "match-none", "match": {"patterns": [{"kind": "given", "pattern": "a known step", "handler": "h"}], "step_text": "an unknown step"}, "expect": "err", "expect_code": "step_unmatched"},
    {"id": "match-ambiguous", "match": {"patterns": [{"kind": "given", "pattern": "a {x}", "handler": "h"}, {"kind": "given", "pattern": "{y} step", "handler": "h"}], "step_text": "a step"}, "expect": "err", "expect_code": "ambiguous_step"},
    {"id": "fold-mixed", "fold": {"feature_name": "Login", "source_path": "login.feature", "scenario_statuses": ["ok", "err", "ok", "err"]}, "expect_passed": 2, "expect_failed": 2},
    {"id": "fold-all-pass", "fold": {"feature_name": "Empty", "source_path": "e.feature", "scenario_statuses": ["ok", "ok"]}, "expect_passed": 2, "expect_failed": 0},
    {"id": "value-step-fault", "value_case": {"function": "step_fault", "args": ["step_unmatched", "no match here"], "expected": {"code": "step_unmatched", "scenario_name": "", "step_text": "", "detail": "no match here"}}},
    {"id": "value-empty-registry", "value_case": {"function": "empty_registry", "args": [], "expected": {"patterns": []}}},
    {"id": "value-parse-feature", "value_case": {"function": "parse_feature", "args": ["Feature: Login\n\n  Scenario: signs in\n    Given a user\n    Then a dashboard\n", "login.feature"], "expected": {"ok": {"name": "Login", "description": "", "scenarios": [{"name": "signs in", "steps": [{"kind": "given", "resolved_kind": "given", "text": "a user", "source_line": 4}, {"kind": "then", "resolved_kind": "then", "text": "a dashboard", "source_line": 5}], "tags": [], "source_line": 3}], "background_steps": [], "source_path": "login.feature"}}}},
    {"id": "value-fold-report", "value_case": {"function": "fold_feature_report", "args": [{"name": "F", "description": "", "scenarios": [], "background_steps": [], "source_path": "f.feature"}, [{"name": "s1", "status": "ok", "step_results": [], "duration_ms": 0}, {"name": "s2", "status": "err", "step_results": [], "duration_ms": 0}]], "expected": {"feature_name": "F", "source_path": "f.feature", "scenarios": [{"name": "s1", "status": "ok", "step_results": [], "duration_ms": 0}, {"name": "s2", "status": "err", "step_results": [], "duration_ms": 0}], "total_passed": 1, "total_failed": 1}}}
  ],
  "value_oracle_exempt": [
    {"function": "compile_pattern", "reason": "Output embeds the compiled regex, whose dialect is per-spoke (section 1.5); not a portable value."},
    {"function": "register_step", "reason": "Output embeds the step handler (a callable); not a portable value."},
    {"function": "match_step", "reason": "Output (StepMatch) embeds the matched pattern's handler (a callable); not a portable value."},
    {"function": "run_step", "reason": "Threads the immutable context shaped by the developer's handler; part of the execution engine the value oracle itself runs on."},
    {"function": "run_scenario", "reason": "Its report carries wall-clock duration (non-deterministic); the scenario runner the value oracle runs on."},
    {"function": "run_feature_file", "reason": "Reads the filesystem and reports wall-clock duration (non-deterministic); verified by its own conformance probe."}
  ]
}