{
  "version": "0.1",
  "module": "honest-type",
  "note": "Unit 1 — vocabulary construction contract (sections 2, 3). Set members as arrays; the runner builds the vocabulary and checks ok vs VocabularyError. classify() cases follow with unit 2.",
  "cases": [
    {"id": "vocab-valid", "declarations": {"currency_code": ["USD", "EUR", "GBP"], "format_name": ["currency", "number", "percent"]}, "expect": "ok"},
    {"id": "vocab-single", "declarations": {"t": ["alpha", "beta"]}, "expect": "ok"},
    {"id": "vocab-no-overlap", "declarations": {"a": ["x"], "b": ["y"]}, "expect": "ok"},
    {"id": "vocab-reserved-class", "declarations": {"x": ["class"]}, "expect": "error", "error_contains": "reserved"},
    {"id": "vocab-reserved-return", "declarations": {"y": ["return", "ok"]}, "expect": "error", "error_contains": "reserved"},
    {"id": "vocab-reserved-manifest", "declarations": {"z": ["manifest"]}, "expect": "error", "error_contains": "framework"},
    {"id": "vocab-overlap", "declarations": {"a": ["x", "y"], "b": ["y", "z"]}, "expect": "error", "error_contains": "share"},

    {"id": "classify-binding", "declarations": {"currency_code": ["USD", "EUR"], "format_name": ["currency", "number"]}, "binding": {"currency_code": "currency", "format_name": "format"}, "tokens": ["currency", "EUR"], "expect_manifest": {"format": "currency", "currency": "EUR"}, "expect_rejections": []},
    {"id": "classify-order-independent", "declarations": {"currency_code": ["USD", "EUR"], "format_name": ["currency", "number"]}, "binding": {"currency_code": "currency", "format_name": "format"}, "tokens": ["EUR", "currency"], "expect_manifest": {"format": "currency", "currency": "EUR"}},
    {"id": "classify-auto-binding", "declarations": {"cc": ["USD", "EUR"]}, "tokens": ["USD"], "expect_manifest": {"cc": "USD"}, "expect_rejections": []},
    {"id": "classify-unrecognized", "declarations": {"cc": ["USD"]}, "tokens": ["zzz"], "expect_rejections": ["unrecognized", "missing_required"]},
    {"id": "classify-duplicate-slot", "declarations": {"format_name": ["currency", "number"]}, "tokens": ["currency", "number"], "expect_manifest": {"format_name": "currency"}, "expect_rejections": ["duplicate_slot"]},
    {"id": "classify-missing-required", "declarations": {"a": ["x"], "b": ["y"]}, "tokens": [], "expect_rejections": ["missing_required"]},
    {"id": "classify-null-token", "declarations": {"cc": ["USD"]}, "tokens": [null, "USD"], "expect_manifest": {"cc": "USD"}, "expect_rejections": ["null_token"]},
    {"id": "classify-empty-token", "declarations": {"cc": ["USD"]}, "tokens": ["", "USD"], "expect_manifest": {"cc": "USD"}, "expect_rejections": ["empty_token"]},

    {"id": "composed-fires", "declarations": {"format_name": ["currency", "number"], "currency_code": ["USD", "EUR"], "integer": ["2", "3"]}, "composed_types": [{"name": "currency_precision", "requires": {"format_name": "currency"}, "captures": "integer"}], "binding": {"format_name": "format", "currency_code": "currency", "integer": "precision", "currency_precision": "decimals"}, "tokens": ["2", "EUR", "currency"], "expect_manifest": {"format": "currency", "currency": "EUR", "decimals": "2"}, "expect_rejections": []},
    {"id": "composed-off-falls-through", "declarations": {"format_name": ["currency", "number"], "currency_code": ["USD", "EUR"], "integer": ["2", "3"]}, "composed_types": [{"name": "currency_precision", "requires": {"format_name": "currency"}, "captures": "integer"}], "binding": {"format_name": "format", "currency_code": "currency", "integer": "precision", "currency_precision": "decimals"}, "tokens": ["2", "EUR", "number"], "expect_manifest": {"format": "number", "currency": "EUR", "precision": "2"}, "expect_rejections": []},
    {"id": "maybe-absent-nothing", "declarations": {"cc": ["USD"], "intg": ["2"]}, "binding": {"cc": "currency", "intg": {"maybe": "precision"}}, "tokens": ["USD"], "expect_manifest": {"currency": "USD", "precision": null}, "expect_rejections": []},
    {"id": "maybe-present-value", "declarations": {"cc": ["USD"], "intg": ["2"]}, "binding": {"cc": "currency", "intg": {"maybe": "precision"}}, "tokens": ["USD", "2"], "expect_manifest": {"currency": "USD", "precision": "2"}, "expect_rejections": []},
    {"id": "composed-maybe-capture-absent", "declarations": {"format_name": ["currency"], "integer": ["2"]}, "composed_types": [{"name": "cp", "requires": {"format_name": "currency"}, "captures": {"maybe": "integer"}}], "binding": {"format_name": "format", "integer": "precision", "cp": "decimals"}, "tokens": ["currency"], "expect_manifest": {"format": "currency", "decimals": null}, "expect_rejections": []},

    {"id": "merge-disjoint", "merge_a": {"currency_code": ["USD", "EUR"]}, "merge_b": {"format_name": ["currency", "number"]}, "expect": "ok"},
    {"id": "merge-name-collision", "merge_a": {"cc": ["USD", "EUR"]}, "merge_b": {"cc": ["GBP"]}, "expect": "error", "error_contains": "both define"},
    {"id": "merge-value-collision", "merge_a": {"a": ["x", "y"]}, "merge_b": {"b": ["y", "z"]}, "expect": "error", "error_contains": "share"},

    {"id": "chain-ok-transforms", "combinator": "chain", "links": ["pass", "set_role"], "initial": {"email": "a@b"}, "expect": "ok", "expect_manifest": {"role": "admin", "email": "a@b"}},
    {"id": "chain-short-circuits-on-fault", "combinator": "chain", "links": ["fault", "set_role"], "initial": {}, "expect": "err", "expect_code": "boom"},
    {"id": "chain-non-result-return", "combinator": "chain", "links": ["bad"], "initial": {}, "expect": "err", "expect_code": "non_result_return"},
    {"id": "validate-all-ok", "combinator": "validate_all", "links": ["pass", "set_role"], "initial": {"x": "1"}, "expect": "ok", "expect_manifest": {"x": "1"}},
    {"id": "validate-all-accumulates-fault", "combinator": "validate_all", "links": ["pass", "fault"], "initial": {}, "expect": "err", "expect_code": "validation_failed"},

    {"id": "boundary-ok-success-output", "links": ["pass", "set_role"], "initial": {}, "expect_status": 200},
    {"id": "boundary-server-fault-default", "links": ["fault"], "initial": {}, "expect_status": 500, "expect_code": "boom"},
    {"id": "boundary-fault-table-hit", "links": ["unrecognized"], "initial": {}, "expect_status": 422, "expect_code": "unrecognized"},
    {"id": "boundary-catches-exception", "links": ["raise"], "initial": {}, "expect_status": 500, "expect_code": "unhandled_exception"},

    {"id": "rejections-block-on-fault", "rejection_manifest": {"cc": "USD", "_rejections": [{"token": "zz", "reason": "unrecognized", "detail": null}]}, "expect": "err", "expect_code": "unrecognized"},
    {"id": "rejections-warn-passes-clean", "rejection_manifest": {"cc": "USD", "_rejections": [{"token": "", "reason": "empty_token", "detail": null}]}, "expect": "ok"}
  ]
}
