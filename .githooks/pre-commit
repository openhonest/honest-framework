#!/usr/bin/env bash
# pre-commit — Verification First: no Python commit lands while the framework fails its
# own linter, its own conformance suites, or its 100% dogfooding bar. Runs only when
# Python sources are staged, so non-Python commits are never blocked. Enabled via
# `core.hooksPath=.githooks` (see bootstrap.sh).
set -uo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^python/.*\.py$' || true)
[ -z "$staged" ] && exit 0

echo "honest-check gate (staged Python detected)…"
root=$(git rev-parse --show-toplevel)
"$root/python/lint-affected.sh" || exit 1   # structural: must be Honest Code
"$root/python/coverage-all.sh"  || exit 1   # behavioural: all conformance suites pass AND 100% line+branch coverage (the dogfooding circle)
