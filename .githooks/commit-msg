#!/bin/bash
# Pre-commit hook: validates commit message prefix for research instrumentation
# Install: cp tools/commit-prefix-hook.sh .git/hooks/commit-msg && chmod +x .git/hooks/commit-msg
#
# Valid prefixes: spec: design: impl: refactor: test: fix: chore: docs:

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

VALID_PREFIXES="^(spec|design|impl|refactor|test|fix|chore|docs):"

if ! echo "$COMMIT_MSG" | grep -qE "$VALID_PREFIXES"; then
    echo ""
    echo "ERROR: Commit message must start with a valid prefix."
    echo ""
    echo "  Valid prefixes:"
    echo "    spec:      Specification changes (.md, .feature)"
    echo "    design:    Architecture decisions, API design"
    echo "    impl:      New code implementing spec requirements"
    echo "    refactor:  Restructuring without behavior change"
    echo "    test:      Test code, coverage improvements"
    echo "    fix:       Bug fixes"
    echo "    chore:     Dependencies, CI/CD, tooling"
    echo "    docs:      README, comments, usage examples"
    echo ""
    echo "  Your message: $COMMIT_MSG"
    echo ""
    exit 1
fi
